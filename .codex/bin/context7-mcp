#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
repo_env_file="$repo_root/.env.local"
codex_env_file="$repo_root/.codex/.env.local"

load_env_file() {
  local file="$1"

  if [[ -f "$file" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$file"
    set +a
  fi
}

load_env_file "$repo_env_file"
load_env_file "$codex_env_file"

if [[ -z "${CONTEXT7_API_KEY:-}" ]]; then
  cat >&2 <<'EOF'
Missing CONTEXT7_API_KEY.

Set CONTEXT7_API_KEY in your shell, or add it to .env.local or .codex/.env.local for this repo.
EOF
  exit 1
fi

exec npx -y @upstash/context7-mcp "$@"
